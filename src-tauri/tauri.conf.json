{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ThuongMinh",
  "version": "1.0.4",
  "identifier": "com.tekki.thuongminh",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ThuongMinh",
        "width": 1280,
        "height": 800,
        "minWidth": 320,
        "minHeight": 568,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}